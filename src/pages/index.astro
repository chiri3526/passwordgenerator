---
import "../styles.css";
import "../redesign.css";
import passwordGeneratorLogo from "../assets/password-generator-logo.png";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A simple password generator that lets you sign in, save presets, and keep password history notes."
    />
    <title>Password Maker | Simple Password Generator</title>
  </head>
  <body>
    <main class="landing-page">
      <section class="landing-hero">
        <div class="landing-inner">
          <div class="landing-copy">
            <img class="landing-logo" src={passwordGeneratorLogo.src} alt="Password Maker" />
            <p class="section-kicker">Password Maker</p>
            <h1>Make strong passwords fast.</h1>
            <p class="landing-lead">
              Choose the length, character types, symbols, and presets you need, then sign in to save your favorite
              settings, history, and notes.
            </p>
            <div class="landing-actions">
              <a class="primary-button" href="/generator">Open Generator</a>
              <a class="secondary-button" href="/generator">Sign In</a>
            </div>
          </div>
          <div class="landing-preview" aria-label="Password Maker key features">
            <div class="preview-row">
              <span>Length</span>
              <strong>16</strong>
            </div>
            <div class="preview-row">
              <span>Symbols</span>
              <strong>- _ !</strong>
            </div>
            <div class="preview-password">N8f-3Lp!xQ_2rZa</div>
            <div class="preview-grid">
              <span>Preset</span>
              <span>History</span>
              <span>Notes</span>
            </div>
          </div>
        </div>
      </section>

      <section class="landing-band" aria-label="Features">
        <div class="landing-feature">
          <strong>Generate</strong>
          <span>Create multiple passwords at once by adjusting the rules to match your needs.</span>
        </div>
        <div class="landing-feature">
          <strong>Save</strong>
          <span>Keep frequently used settings as presets so you can reuse them quickly.</span>
        </div>
        <div class="landing-feature">
          <strong>Track</strong>
          <span>Add notes to saved entries and review the context later without storing plain-text passwords.</span>
        </div>
      </section>
    </main>
  </body>
</html>
